# Secrets
TELEGRAM_TOKEN=REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# Optional
OPENAI_MODEL=gpt-4o-mini
# For local Ollama OpenAI-compatible endpoint:
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# Edge Impulse MCP (used by ei-mcp-bridge)
EI_API_KEY=ei-REPLACE_ME
# EI_JWT_TOKEN=jwt-REPLACE_ME
EI_MCP_VERBOSE=1
EI_MCP_LOG_REQUESTS=1
EI_MCP_PORT=8090
EI_MCP_REQUEST_TIMEOUT_MS=120000
# Override only if you run the MCP server elsewhere or from a different path
# EI_MCP_CMD="node /path/to/ei-agentic-claude/dist/mcp-server.js"
# Safer alternative to EI_MCP_CMD (used when EI_MCP_CMD is not set)
# EI_MCP_BIN=node
# EI_MCP_ARGS=/usr/local/lib/node_modules/ei-agentic-claude/dist/mcp-server.js
# Local repo mode (compose profile `mcp-local`)
EI_AGENTIC_CLAUDE_PATH=/home/pi/ei-agentic-claude
EI_MCP_BIN_LOCAL=node
EI_MCP_ARGS_LOCAL=/opt/ei-agentic-claude/dist/mcp-server.js
# Prebuilt image mode (compose profile `mcp-image`)
EI_MCP_BASE_IMAGE=docker.io/eoinedge/ei-agentic-claude-mcp:latest
EI_MCP_BIN_IMAGE=node
EI_MCP_ARGS_IMAGE=/app/dist/mcp-server.js

# Gateway config
GATEWAY_PORT=3000
GATEWAY_LOG_REQUESTS=1
# If you call the gateway from another device, set this to the Pi IP (e.g. http://192.168.1.50:3000).
GATEWAY_URL=http://127.0.0.1:3000

# MCP upstreams
ARDUINO_MCP=http://127.0.0.1:3080
# EI_MCP should point to an HTTP bridge for the `ei-agentic-claude` MCP server (stdio -> HTTP).
EI_MCP=http://127.0.0.1:8090

# Demo default
# If you use the compose profile for Arduino MCP, put sketches under ./workspace/Arduino
DEFAULT_ARDUINO_PROJECT_ROOT=/workspace/Blink
